{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "runner-schema.v1.json",
  "title": "Omini Runner Payload v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "message",
    "memory",
    "history",
    "summary",
    "capabilities",
    "session"
  ],
  "properties": {
    "message": {
      "type": "string",
      "minLength": 1
    },
    "memory": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "nome": {
          "type": "string"
        },
        "preferencias": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "history": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "role",
          "content"
        ],
        "properties": {
          "role": {
            "type": "string",
            "enum": [
              "user",
              "assistant"
            ]
          },
          "content": {
            "type": "string"
          }
        }
      }
    },
    "summary": {
      "type": "string"
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "description"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "category": {
            "type": "string"
          }
        }
      }
    },
    "session": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "session_id": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "history": {
          "type": "array"
        }
      }
    }
  }
}
