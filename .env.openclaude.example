# Copy this file to `.env.openclaude.local` and fill in only the providers you use.
# The PowerShell launchers in `scripts/` load `.env.openclaude.local` automatically.

# OpenAI-compatible / Codex mode
OPENAI_API_KEY=COLOCAR_CHAVE_AQUI
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional Codex overrides
# If you already use the Codex CLI, `CODEX_AUTH_JSON_PATH` can point to your existing auth file.
CODEX_AUTH_JSON_PATH=C:\Users\Misael\.codex\auth.json
CODEX_API_KEY=

# Optional local Ollama defaults
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5-coder:7b

# Optional web search/fetch upgrade for OpenClaude
FIRECRAWL_API_KEY=
