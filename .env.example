# ===============================
# OMNI CORE PROVIDERS
# ===============================
OMNI_OPENAI_API_KEY=<OPENAI_API_KEY>
# Deprecated compatibility alias; prefer OMNI_OPENAI_API_KEY.
OMINI_OPENAI_API_KEY=<OPENAI_API_KEY_LEGACY_ALIAS>
OPENAI_API_KEY=<OPENAI_API_KEY>
OPENAI_MODEL=<OPENAI_MODEL>
ANTHROPIC_API_KEY=<ANTHROPIC_API_KEY>
ANTHROPIC_MODEL=<ANTHROPIC_MODEL>
GROQ_API_KEY=<GROQ_API_KEY>
GROQ_MODEL=<GROQ_MODEL>
OPENROUTER_API_KEY=<OPENROUTER_API_KEY>
OPENROUTER_MODEL=<OPENROUTER_MODEL>
GEMINI_API_KEY=<GEMINI_API_KEY>
GEMINI_MODEL=<GEMINI_MODEL>
DEEPSEEK_API_KEY=<DEEPSEEK_API_KEY>
DEEPSEEK_MODEL=<DEEPSEEK_MODEL>
CODEX_API_KEY=<CODEX_API_KEY>

# ===============================
# LOCAL / RUNTIME
# ===============================
OLLAMA_URL=<OLLAMA_URL>
OLLAMA_MODEL=<OLLAMA_MODEL>
OLLAMA_API_KEY=<OLLAMA_API_KEY_OPTIONAL>
LMSTUDIO_URL=<LMSTUDIO_URL>
LMSTUDIO_MODEL=<LMSTUDIO_MODEL>
LMSTUDIO_API_KEY=<LMSTUDIO_API_KEY_OPTIONAL>
OMNI_JS_RUNTIME_BIN=node
# Bun is opt-in only:
# OMNI_JS_RUNTIME_BIN=bun
# Deprecated compatibility alias: OMINI_JS_RUNTIME_BIN

# ===============================
# SUPABASE (PUBLIC SAFE)
# ===============================
SUPABASE_URL=<SUPABASE_URL>
SUPABASE_ANON_KEY=<SUPABASE_ANON_KEY>
# Server-side only: optional inserts into public.runtime_tool_events (never expose to frontend).
SUPABASE_SERVICE_ROLE_KEY=<SUPABASE_SERVICE_ROLE_KEY>

# ===============================
# ENCRYPTED CREDENTIAL STORE (P5D)
# ===============================
# AES-256-GCM encryption key for credential persistence.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Must be exactly 64 hexadecimal characters (32 bytes / 256 bits).
# OMNI_CREDENTIAL_STORE_KEY=<64_HEX_CHARS>
# OMINI_CREDENTIAL_STORE_KEY=<64_HEX_CHARS_LEGACY_ALIAS>
# Optional: path to the encrypted credential store file (default: credentials.enc)
# OMNI_CREDENTIAL_STORE_PATH=credentials.enc

# OMNI_* is canonical for new variables where applicable.
# OMINI_* remains supported as a legacy compatibility prefix where already used.
