# ===============================
# OMNI CORE PROVIDERS
# ===============================
OMNI_OPENAI_API_KEY=<OPENAI_API_KEY>
OMINI_OPENAI_API_KEY=<OPENAI_API_KEY_LEGACY_ALIAS>
OPENAI_API_KEY=<OPENAI_API_KEY>
ANTHROPIC_API_KEY=<ANTHROPIC_API_KEY>
GROQ_API_KEY=<GROQ_API_KEY>
GEMINI_API_KEY=<GEMINI_API_KEY>
DEEPSEEK_API_KEY=<DEEPSEEK_API_KEY>
CODEX_API_KEY=<CODEX_API_KEY>

# ===============================
# LOCAL / RUNTIME
# ===============================
OLLAMA_URL=<OLLAMA_URL>

# ===============================
# SUPABASE (PUBLIC SAFE)
# ===============================
SUPABASE_URL=<SUPABASE_URL>
SUPABASE_ANON_KEY=<SUPABASE_ANON_KEY>
# Server-side only: optional inserts into public.runtime_tool_events (never expose to frontend).
SUPABASE_SERVICE_ROLE_KEY=<SUPABASE_SERVICE_ROLE_KEY>

# OMNI_* is canonical for new variables where applicable.
# OMINI_* remains supported as a legacy compatibility prefix where already used.
