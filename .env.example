# Base directories
BASE_DIR=/app
PYTHON_BASE_DIR=/app/backend/python
NODE_RUNNER_BASE_DIR=/app

# Rust API
APP_HOST=0.0.0.0
APP_PORT=3001
PYTHON_BIN=python
PYTHON_ENTRY=../python/main.py
MOCK_CHAT=false

# Python brain
AI_SESSION_ID=python-session
MEMORY_JSON_PATH=/app/backend/python/memory.json
MEMORY_DIR=/app/backend/python/memory
TRANSCRIPTS_DIR=/app/backend/python/transcripts
SESSIONS_DIR=/app/backend/python/brain/runtime/sessions

# Node runner
NODE_BIN=node
RUNNER_SCHEMA_PATH=/app/contract/runner-schema.v1.json
RUNNER_ADAPTER_PATH=/app/src/queryEngineRunnerAdapter.js

# Deployment
SERVER_IP=
SERVER_USER=deploy
SSH_PRIVATE_KEY=

# Supabase auth
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=your_supabase_jwt_secret

# AI providers (server / Node subprocess — never commit real values)
OPENAI_API_KEY=
OPENAI_MODEL=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
GROQ_API_KEY=
GROQ_MODEL=
CODEX_API_KEY=
CHATGPT_ACCOUNT_ID=

# Local models
OLLAMA_URL=
OLLAMA_MODEL=
